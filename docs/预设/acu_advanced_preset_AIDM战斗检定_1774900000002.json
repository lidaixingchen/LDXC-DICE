{
  "kind": "advanced",
  "version": "1.7.0",
  "id": "aidm_combat_check",
  "name": "AIDM战斗检定",
  "description": "AIDM战斗检定：用于战斗场景的攻击检定，包含暴击和伤害计算。DDC由目标等级决定。",
  "diceExpression": "1d20",
  "attribute": {
    "label": "属性值",
    "placeholder": "留空=10",
    "defaultValue": 10,
    "key": "属性值",
    "computeModifier": "max(0, floor(($attr - 6) / 10))"
  },
  "dc": {
    "label": "目标DDC",
    "placeholder": "留空=10",
    "defaultValue": 10
  },
  "mod": {
    "label": "额外修正",
    "placeholder": "装备/技能等",
    "defaultValue": 0
  },
  "skillMod": {
    "label": "掌握加成",
    "placeholder": "等级加成",
    "defaultValue": 0
  },
  "attrTargetMapping": {
    "attribute": ["力量", "敏捷", "体质", "智力", "感知", "魅力"]
  },
  "customFields": [
    {
      "id": "baseDdc",
      "type": "select",
      "label": "目标等级(基础DDC)",
      "defaultValue": 10,
      "options": [
        { "label": "F级", "value": 10 },
        { "label": "E级", "value": 13 },
        { "label": "D级", "value": 16 },
        { "label": "C级", "value": 19 },
        { "label": "B级", "value": 22 },
        { "label": "A级", "value": 25 },
        { "label": "S级", "value": 28 },
        { "label": "SS级", "value": 31 },
        { "label": "SSS级", "value": 34 }
      ]
    },
    {
      "id": "targetDodgeMod",
      "type": "number",
      "label": "目标闪避加值",
      "defaultValue": 0,
      "placeholder": "目标敏捷/感知加成+装备闪避"
    },
    {
      "id": "attackType",
      "type": "select",
      "label": "攻击类型",
      "defaultValue": "物理",
      "options": [
        { "label": "物理攻击", "value": "物理" },
        { "label": "法术攻击", "value": "法术" }
      ]
    },
    {
      "id": "charisma",
      "type": "number",
      "label": "魅力值",
      "defaultValue": 10,
      "placeholder": "用于计算暴击率"
    },
    {
      "id": "attackPower",
      "type": "number",
      "label": "攻击力",
      "defaultValue": 10,
      "placeholder": "物理/法术攻击力"
    },
    {
      "id": "targetDefense",
      "type": "number",
      "label": "目标防御",
      "defaultValue": 5,
      "placeholder": "物理/法术防御"
    }
  ],
  "derivedVars": [
    {
      "id": "finalDc",
      "expr": "$baseDdc + $targetDodgeMod"
    },
    {
      "id": "targetLevelName",
      "expr": "$baseDdc == 10 ? 'F' : ($baseDdc == 13 ? 'E' : ($baseDdc == 16 ? 'D' : ($baseDdc == 19 ? 'C' : ($baseDdc == 22 ? 'B' : ($baseDdc == 25 ? 'A' : ($baseDdc == 28 ? 'S' : ($baseDdc == 31 ? 'SS' : 'SSS')))))))"
    },
    {
      "id": "critRate",
      "expr": "min(50, 5 + floor($charisma / 2))"
    },
    {
      "id": "isCrit",
      "expr": "$roll.total <= $critRate / 5"
    },
    {
      "id": "defRatio",
      "expr": "$targetDefense / $attackPower"
    },
    {
      "id": "damageReduction",
      "expr": "$defRatio < 0.5 ? 0 : ($defRatio < 0.8 ? 0.2 : ($defRatio < 1 ? 0.4 : ($defRatio < 1.5 ? 0.6 : 0.8)))"
    },
    {
      "id": "baseDamage",
      "expr": "max(1, floor($attackPower * (1 - $damageReduction)))"
    },
    {
      "id": "finalDamage",
      "expr": "$isCrit ? $baseDamage * 2 : $baseDamage"
    }
  ],
  "outcomes": [
    {
      "id": "crit_hit",
      "name": "暴击命中",
      "condition": "$isCrit && ($roll.total + $attrMod + $skillMod + $mod >= $finalDc)",
      "priority": 1,
      "rank": 3,
      "outputText": "AIDM战斗检定: 暴击命中！造成双倍伤害。"
    },
    {
      "id": "hit",
      "name": "命中",
      "condition": "$roll.total + $attrMod + $skillMod + $mod >= $finalDc",
      "priority": 10,
      "rank": 1,
      "outputText": "AIDM战斗检定: 命中目标！"
    },
    {
      "id": "miss",
      "name": "未命中",
      "condition": "$roll.total + $attrMod + $skillMod + $mod < $finalDc",
      "priority": 20,
      "rank": 0,
      "outputText": "AIDM战斗检定: 未命中！"
    }
  ],
  "contestRule": {
    "disabled": true
  },
  "outputTemplate": "<meta:检定结果>\n【AIDM战斗检定】\n\n🎲 判定过程：\n・D20投骰：$roll.total\n・属性加成：$attrMod（$attrName: $attrValue）\n・掌握加成：$skillMod\n・额外修正：$mod\n・最终值：$roll.total + $attrMod + $skillMod + $mod\n\n📊 DDC对比：$roll.total + $attrMod + $skillMod + $mod $judgeResult $finalDc\n（目标等级$targetLevelName级，基础DDC $baseDdc，闪避加值$targetDodgeMod）\n$outcomeText\n\n⚔️ 伤害计算：\n・攻击力：$attackPower\n・目标防御：$targetDefense\n・伤害减免：${damageReduction * 100}%\n・基础伤害：$baseDamage\n最终伤害：$finalDamage\n</meta:检定结果>",
  "visible": true,
  "order": 1
}
