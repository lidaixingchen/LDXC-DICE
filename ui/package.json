{
  "name": "acu-dice-system",
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "presync": "pnpm sync-config",
    "dev": "pnpm presync && vite build --watch --mode development",
    "build": "pnpm presync && vite build",
    "build:prod": "pnpm presync && vite build --mode production",
    "preview": "vite preview",
    "lint": "eslint src --ext .ts,.vue",
    "typecheck": "pnpm presync && vue-tsc --noEmit",
    "test": "pnpm presync && vitest run",
    "test:watch": "pnpm presync && vitest",
    "test:coverage": "pnpm presync && vitest run --coverage",
    "sync-config": "tsx scripts/sync-numerical-config.ts"
  },
  "dependencies": {
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/test-utils": "^2.4.0",
    "@vue/tsconfig": "^0.5.0",
    "happy-dom": "^13.0.0",
    "js-yaml": "^4.1.1",
    "sass": "^1.69.0",
    "terser": "^5.46.1",
    "tsx": "^4.21.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0",
    "vue-tsc": "^2.0.0"
  },
  "peerDependencies": {
    "vue": "^3.0.0"
  }
}
